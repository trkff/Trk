            "command": "python -c \"import sys,json; d=json.load(sys.stdin); p=d.get('tool_input',{}).get('file_path',''); is_py=p.endswith('.py') and 'hyperliquid-bot' in p and '__init__.py' not in p and '__pycache__' not in p; msg='[LEMBRETE AUTOMÁTICO] Um arquivo Python do projeto foi modificado. Se a mudança introduz novos módulos, altera a arquitetura, muda o schema do banco, adiciona/remove parâmetros de config ou afeta qualquer coisa documentada em hyperliquid-bot/CLAUDE.md — atualize o CLAUDE.md para refletir a mudança antes de finalizar.'; print(json.dumps({'hookSpecificOutput':{'hookEventName':'PostToolUse','additionalContext':msg}}) if is_py else '{}')\""
          }
        ]
      }
    ]
